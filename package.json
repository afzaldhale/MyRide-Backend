{
  "name": "ride-app-platform-backend",
  "version": "1.0.0",
  "description": "Production-grade backend for a ride-sharing platform monorepo",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
    "db:migrate": "sequelize-cli db:migrate --config sequelize.config.js",
    "db:migrate:undo": "sequelize-cli db:migrate:undo --config sequelize.config.js",
    "worker:sessions": "node src/workers/sessionCleanup.worker.js"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.2",
    "firebase-admin": "^13.4.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "mysql2": "^3.15.2",
    "node-cron": "^4.2.1",
    "sequelize": "^6.37.7",
    "sequelize-cli": "^6.6.5",
    "socket.io": "^4.8.3",
    "ua-parser-js": "^2.0.9",
    "uuid": "^11.1.0",
    "winston": "^3.19.0"
  }
}
