PORT=5000
NODE_ENV=development
APP_NAME=ride-platform-backend
APP_VERSION=1.0.0
TRUST_PROXY=false
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=info
SHUTDOWN_TIMEOUT_MS=10000
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX_REQUESTS=120
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=ride_app_db
DB_SYNC=false
DB_POOL_MAX=20
DB_POOL_MIN=2
DB_POOL_ACQUIRE_MS=30000
DB_POOL_IDLE_MS=10000
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=change_this_to_a_different_long_random_secret
REFRESH_TOKEN_EXPIRES_IN=30d
REFRESH_TOKEN_TTL_DAYS=30
MAX_ACTIVE_SESSIONS_PER_USER=5
SESSION_CACHE_TTL_SECONDS=300
USER_CACHE_TTL_SECONDS=300
REDIS_FAILURE_COOLDOWN_MS=10000
SESSION_CLEANUP_CRON=*/15 * * * *
SESSION_CLEANUP_BATCH_SIZE=500
SESSION_RETENTION_DAYS=30
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
SOCKET_CORS_ORIGIN=*
REDIS_URL=redis://127.0.0.1:6379
REDIS_KEY_PREFIX=ride_app:
MATCHING_RADIUS_KM=5
MATCHING_MAX_INITIAL_DRIVERS=3
MATCHING_DRIVER_RESPONSE_TIMEOUT_MS=12000
DRIVER_LOCATION_THROTTLE_MS=2500
